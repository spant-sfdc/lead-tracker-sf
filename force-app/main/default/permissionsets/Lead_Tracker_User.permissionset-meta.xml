<?xml version="1.0" encoding="UTF-8"?>
<PermissionSet xmlns="http://soap.sforce.com/2006/04/metadata">
    <description>Grants access to the Lead Tracker application, pipeline board tab, and Lead object CRUD required for pipeline management.</description>
    <hasActivationRequired>false</hasActivationRequired>
    <label>Lead Tracker User</label>
    <userLicense>Salesforce</userLicense>
    <applicationVisibilities>
        <application>LeadTracker</application>
        <visible>true</visible>
    </applicationVisibilities>
    <objectPermissions>
        <allowCreate>true</allowCreate>
        <allowDelete>false</allowDelete>
        <allowEdit>true</allowEdit>
        <allowRead>true</allowRead>
        <modifyAllRecords>false</modifyAllRecords>
        <object>Lead</object>
        <viewAllRecords>false</viewAllRecords>
    </objectPermissions>
    <tabSettings>
        <tab>Lead_Tracker</tab>
        <visibility>Available</visibility>
    </tabSettings>
    <tabSettings>
        <tab>standard-Lead</tab>
        <visibility>Available</visibility>
    </tabSettings>
</PermissionSet>
